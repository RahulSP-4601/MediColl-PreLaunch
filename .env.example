# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Configuration (Shared with QuickBook24 Product)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Amazon SES (Email Service - Production - Cost-effective for India)
# Mumbai region (ap-south-1) for best performance in India
# Cost: ~₹1,000/month for 50,000 emails (~₹0.10 per 1,000 emails)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SES_FROM_EMAIL=MediColl24 <noreply@medicoll24.com>
AWS_SES_REPLY_TO=support@medicoll24.com
FROM_NAME=Rahul Sanjay Panchal

# Email Rate Limiting (AWS SES production limits)
DAILY_EMAIL_LIMIT=10000
HOURLY_EMAIL_LIMIT=1000
MIN_DELAY_SECONDS=2

# Twilio Configuration (WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Waitlist & Unsubscribe URLs
NEXT_PUBLIC_WAITLIST_URL=https://quickbook24.ai/waitlist
NEXT_PUBLIC_UNSUBSCRIBE_URL=https://your-app-url.vercel.app/unsubscribe

# Cron Job Security (IMPORTANT: Change this in production!)
CRON_SECRET=your-strong-random-secret-here

# Founder Dashboard Access (IMPORTANT: Change this!)
NEXT_PUBLIC_FOUNDER_PASSWORD=your-secure-password-here

# WhatsApp Toggle (set to 'true' to enable WhatsApp messages)
ENABLE_WHATSAPP=false
