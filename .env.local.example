# ===========================================
# MediColl24-Sales Next.js Configuration
# ===========================================

# -----------------
# Database (Supabase - Same as MediColl24 Product)
# -----------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------
# Email (SMTP)
# -----------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=rahul@medicoll24.ai
FROM_NAME=Rahul Sanjay Panchal

# Email Limits
DAILY_EMAIL_LIMIT=500
HOURLY_EMAIL_LIMIT=50
MIN_DELAY_SECONDS=30

# -----------------
# WhatsApp (Twilio)
# -----------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# WhatsApp Limits
DAILY_WHATSAPP_LIMIT=100
WHATSAPP_DELAY_SECONDS=5

# -----------------
# Tracking
# -----------------
NEXT_PUBLIC_TRACKING_DOMAIN=track.medicoll24.com
NEXT_PUBLIC_UNSUBSCRIBE_URL=https://medicoll24.ai/unsubscribe
NEXT_PUBLIC_WAITLIST_URL=https://medicoll24.ai/waitlist

# -----------------
# Scraping
# -----------------
# Google Maps API (Optional)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# User Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# -----------------
# Target Audience
# -----------------
TARGET_TYPES=clinic,hospital
TARGET_CITIES=Mumbai,Delhi,Bangalore,Pune,Hyderabad,Chennai,Kolkata,Ahmedabad

# -----------------
# Feature Flags
# -----------------
ENABLE_WHATSAPP=true
ENABLE_SOCIAL_MEDIA_FINDER=true
ENABLE_ENHANCED_EMAIL_EXTRACTION=true

# -----------------
# Cron Secret (for API route protection)
# -----------------
CRON_SECRET=your-random-secret-key-here
